	<queryString>
		<![CDATA[select * from vw_facturacion  where (fechaFactura between '$P{fechaInicio}' and '$P{fechaFin}')
and pagare like if('$P{pagare}'='0',"%",CONCAT("%",'$P{pagare}',"%"))
and codigoCliente like if('$P{cliente}'='0',"%",CONCAT("%",'$P{cliente}',"%"))
and codVendedor like if('$P{vendedor}'='0',"%",CONCAT("%",'$P{vendedor}',"%"))
and documento like if('$P{documento}'='0',"%",CONCAT("%",'$P{documento}',"%"))
and valTipoFacturacion like if('$P{tipoFacturacion}'='0',"%",$P{tipoFacturacion})
and tipoVenta like if($P{tipoVenta}='0',"%",$P{tipoVenta})]]>
	</queryString>
