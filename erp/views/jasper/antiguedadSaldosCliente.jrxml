	<queryString>
		<![CDATA[SELECT
    *
FROM
    vw_antiguedadSaldos
where
    fechaReporte between $P{fechaInicio} and $P{fechaFin}
    and idEmpresas=$P{idEmpresas}
    and idClientes=$P{idClientes}
order by fechaReporte]]>
	</queryString>
