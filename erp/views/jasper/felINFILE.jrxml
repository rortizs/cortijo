<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="fel-chs" language="groovy" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="39cbbeea-317e-4546-aa3b-acf14de5fd03">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="304"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
                ventas.*,
                empresas.razonSocial,
                empresas.nit as nitEmpresa,
                sucursales.direccion as direccionEmpresa,
                ventasDetalle.cantidad,
                ventasDetalle.descLarga,
                ventasDetalle.precio,
                ventasDetalle.total as totalProducto,
                empresas.logo,
                sucursales.descripcion as nombreComercial,
                empresas.regimenISR,
                'FACTURA ELECTRONICA' as tipoFEL,
                date_format(fechaFactura,'%d-%m-%Y') as fechaFact,
                date_format(fechaEmisionFEL,'%d-%m-%Y %H:%i:%s') as fechaFEL,
                SUBSTRING_INDEX(conceptoVenta,' - ',1) as concepto,
                SUBSTRING_INDEX(conceptoVenta,' - ',-1) as fcam,
                if(agenteRetenedor=0,'','AGENTE RETENEDOR DE IVA') as agenteRetenedor
                from
                ventas
                left join ventasDetalle on(ventas.id=ventasDetalle.idVentas)
                inner join empresas on(ventas.idEmpresas=empresas.id)
                inner join sucursales on(ventas.idSucursales=sucursales.id)
                where ventas.id=$P{idVenta}]]>
	</queryString>
