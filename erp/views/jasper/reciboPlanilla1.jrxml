	<field name="prestamosPQ" class="java.lang.Double"/>
	<field name="creditoPQ" class="java.lang.Double"/>
	<field name="otrosPQ" class="java.lang.Double"/>
	<field name="faltantesPQ" class="java.lang.Double"/>
	<field name="uniformes" class="java.lang.Double"/>
	<field name="bantrab" class="java.lang.Double"/>
	<field name="seguro" class="java.lang.Double"/>
	<field name="diasTrabajadosPQ" class="java.lang.Double"/>
	<field name="diasTrabajadosSQ" class="java.lang.Double"/>
	<field name="comisiones" class="java.lang.Double"/>
	<field name="tipoCalculoISR" class="java.lang.Integer"/>
	<variable name="totalRecibir" class="java.lang.Double" resetType="Page" calculation="Sum">
		<variableExpression><![CDATA[($F{salarioOrdinario}/2)+$F{bonificacion}+$F{comisiones}]]></variableExpression>
		<initialValueExpression><![CDATA[0.00]]></initialValueExpression>
	</variable>
