		<fieldDescription><![CDATA[Salario Ordinario,3]]></fieldDescription>
	</field>
	<field name="quincena" class="java.lang.Double"/>
	<field name="totalRecibir" class="java.lang.Double"/>
	<field name="totalDeducciones" class="java.lang.Double"/>
	<field name="totalQuincena" class="java.lang.Double"/>
