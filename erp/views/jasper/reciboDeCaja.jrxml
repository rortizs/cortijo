<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="reciboDeCaja" language="groovy" pageWidth="612" pageHeight="360" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0ba01e79-59e9-44aa-b958-7673c07d234d">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idRecibos" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    day(cxc.created_at) as day,
    month(cxc.created_at) as month,
    year(cxc.created_at) as year,
    clientes.nombreC,
    cxc.montoEnLetras,
    cxc.concepto,
    cxc.debitos,
    cxc.chequeNo,
    cxc.noDeCuenta,
    cxc.nombreDelBanco,
    cxc.nombreDelaCuenta,
    cxc.valorDeCheque,
    if(idMonedas=1,'X','') as quetzales,
    if(idMonedas=2,'X','') as dolares
FROM
    cxc
    inner join clientes on(cxc.idClientes=clientes.id)
WHERE
    cxc.id = $P{idRecibos};]]>
	</queryString>
	<field name="month" class="java.lang.Long"/>
