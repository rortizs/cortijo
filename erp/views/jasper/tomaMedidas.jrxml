	<parameter name="idTomaMedida" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select t.id,DATE_FORMAT(t.fechaEntrega,'%d-%m-%Y') as fechaEntrega,DATE_FORMAT(t.fechaGraduacion,'%d-%m-%Y') as fechaGraduacion,DATE_FORMAT(t.fechaRecoger,'%d-%m-%Y') as fechaRecoger,t.idEmpresas,t.observaciones as observacionesT,m.apellido,m.nombre,m.hombro,m.manga,m.altura,m.cabeza,m.noRecibo,m.observaciones,
upper(p.documento) as documento,p.nit,p.nombre as nombrePedido
from tomaMedidas t
inner join tomaMedidasDetalle m on (t.id=m.idTomaMedidas)
inner join pedidos p on(p.id=t.idPedidos)
WHERE t.id=$P{idTomaMedida}]]>
	</queryString>
