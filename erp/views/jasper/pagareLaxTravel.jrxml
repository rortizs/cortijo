<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="pagareLaxTravel" language="groovy" pageWidth="612" pageHeight="396" orientation="Landscape" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="ced07936-e268-4800-b36c-a74185cc6765">
	<property name="ireport.zoom" value="1.0000000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    e.nombreComercial,
    e.direccion,
    e.telefono,
    DATE_FORMAT(v.fechaFactura, '%d/%m/%Y') AS fechaFactura,
    c.codigo AS codigoCliente,
    c.nombreC,
    c.direccionC,
    av.boleto,
    av.pasajero,
    SUBSTR(`av`.`codigoLineaArea`,
        1,
        (LENGTH(`av`.`codigoLineaArea`) - 1)) AS codigoLineaArea,
    DATE_FORMAT(v.fechaFactura, '%d/%m/%Y') AS fecha,
    cast(av.montoSinImpuestos as decimal(10,2)) AS compTarifa,
    cast((av.totalImpuestos - (av.montoSinImpuestos * 0.12)) as decimal(10,2)) AS otros,
    '0.00' AS montoImpuesto,
    cast(av.montoTotal as decimal(10,2)) as montoTotal,
    cast((av.montoSinImpuestos * 0.12) as decimal(10,2)) AS iva,
    av.formaPago,
    v.totalEnLetras,
    cast(v.total as decimal(10,2)) as total,
    cast(v.descuento as decimal(10,2)) as descuento,
    cast(av.tasaCambio as decimal(10,2)) as tasaCambio,
    cast((vd.fee * av.tasaCambio) as decimal(10,2)) AS fee,
    cast(vd.total as decimal(10,2)) AS subtotalBoleto,
    v.direccion AS direccionF,
    cast(CASE av.formaPago
        WHEN 'CASH' THEN (vd.total - (vd.fee * av.tasaCambio))
        ELSE '0.00'
    END as decimal(10,2)) AS efectivo,
    cast(CASE av.formaPago
        WHEN 'CASH' THEN '0.00'
        ELSE (vd.total - (vd.fee * av.tasaCambio))
    END as decimal(10,2)) AS tarjeta,
    av.codVendedor,
    v.serie,
    v.correlativo,
    v.seriePagare,
    v.correlativoPagare,
    cast(v.cargosXServicio as decimal(10,2)) as cargosXServicio,
    cast((vd.total - vd.fee) as decimal(10,2)) AS totalPago
FROM
    agenciasViajes AS av
        INNER JOIN
    ventasDetalle AS vd ON vd.idProducto = av.id
        INNER JOIN
    ventas AS v ON v.id = vd.idVentas
        INNER JOIN
    empresas AS e ON e.codAgencia = av.codAgencia
        LEFT JOIN
    clientes AS c ON c.id = v.idClientes
WHERE
    v.id =$P{idVenta}]]>
	</queryString>
