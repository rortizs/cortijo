	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idAjustes" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*,
    c.sku,
    ifnull(b.serie,'N/A') as serie,
    c.descLarga,
    if(a.idTipoAjustes='Positivo',b.ingreso,b.salida) as cantidad
FROM
    vw_ajustes as a
    left join inventarios as b on(a.documento=b.documento)
    inner join productos as c on(b.idProductos=c.id)
where
    a.id=$P{idAjustes}]]>
	</queryString>
