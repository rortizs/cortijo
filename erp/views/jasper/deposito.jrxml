	<parameter name="idDeposito" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    *, upper(n.descripcion) as cuentaContable
FROM
    vw_depositos as v
    left join partidas as p on(v.idPartidas=p.numero)
    left join partidasDetalle as pd on (p.id=pd.idPartidas)
    left join nomenclatura as n on (pd.idNomenclatura=n.id)
    where v.id=$P{idDeposito}]]>
	</queryString>
