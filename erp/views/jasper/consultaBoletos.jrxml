	<queryString>
		<![CDATA[SELECT * FROM vw_boletos
where (fecha2 between '$P{fechaInicio}' and '$P{fechaFin}')
and boleto like if('$P{boleto}'='0',"%",CONCAT("%",'$P{boleto}',"%"))
and pagare like if('$P{pagare}'='0',"%",CONCAT("%",'$P{pagare}',"%"))
and codCliente like if('$P{cliente}'='0',"%",CONCAT("%",'$P{cliente}',"%"))
and codVendedor like if('$P{vendedor}'='0',"%",CONCAT("%",'$P{vendedor}',"%"))
and codigoLineaAerea like if('$P{lineaAerea}'='0',"%",CONCAT("%",'$P{lineaAerea}',"%"))
and pasajero like if('$P{pasajero}'='0',"%",CONCAT("%",'$P{pasajero}',"%"))
and tarjeta $P{tarjeta}]]>
	</queryString>
