	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    nombre,
    nit,
    direccion,
    conceptoVenta,
    total,
    totalEnLetras,
    date_format(fechaFactura,'%d') as diaFactura,
    date_format(fechaFactura,'%m') as mesFactura,
    date_format(fechaFactura,'%Y') as yearFactura
FROM
    ventas left join clientes on(ventas.nit=clientes.nitC)
where
    ventas.id=$P{idVenta} ]]>
	</queryString>
	<field name="nombre" class="java.lang.String">
