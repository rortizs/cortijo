	<parameter name="fechaFin" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="fechaInicio" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idHrmDepartamentos" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idHrmPlanilla" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
                    g.cuenta as centrosCosto,
                    concat(a.primerNombre,' ',a.segundoNombre,' ',a.tercerNombre,' ',a.primerApellido,' ',a.segundoApellido,' ',a.apellidoCasada) as nombreEmpleado,
                    b.descripcion as puesto,
                    e.descripcion as cdr,
                    date_format(a.fechaIngreso,'%d-%m-%Y') as fechaIngreso,
                    a.salarioOrdinario,
                    (a.salarioOrdinario/2) as quincena,
                    ((a.salarioOrdinario/2)+a.bonificacion+ifnull((select sum(valor) from hrmComisiones where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)) as totalRecibir,
                    (
				    ifnull((select sum(valor) from hrmAnticipos where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) +
                    ifnull((select valor from hrmPrestamos where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='CREDITO' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='OTROS' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='FALTANTES' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='UNIFORMES' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='BANTRAB' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) +
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='SEGURO' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+((d.seguroSocial/100)*(a.salarioOrdinario/2)))
                    as totalDeducciones,
					((a.salarioOrdinario/2)+a.bonificacion+ifnull((select sum(valor) from hrmComisiones where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0))-
					    (
				    ifnull((select sum(valor) from hrmAnticipos where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) +
                    ifnull((select valor from hrmPrestamos where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='CREDITO' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='OTROS' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='FALTANTES' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='UNIFORMES' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='BANTRAB' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) +
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='SEGURO' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0)+((d.seguroSocial/100)*(a.salarioOrdinario/2)))
					as totalQuincena,
                    a.bonificacion,
                    c.descripcion as formaPago,
                    d.seguroSocial,
	         (d.seguroSocial/100)*(a.salarioOrdinario/2) as igss,
                    d.isr,
                    d.deduccionSinComprobacion,
                    d.ingresoSujetosISR,
                    ifnull((select sum(valor) from hrmAnticipos where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as anticipos,
                    ifnull((select valor from hrmPrestamos where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as prestamosSQ,
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='CREDITO' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as creditoSQ,
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='OTROS' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as otrosSQ,
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='FALTANTES' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as faltantesSQ,
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='UNIFORMES' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as uniformes,
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='BANTRAB' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as bantrab,
                    ifnull((select sum(valor) from hrmOtrosPagosDescuentos where idHrmEmpleados=a.id and idHrmTipoPago=2 and descripcion='SEGURO' and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as seguro,
                    ((if(DATEDIFF($P{fechaFin}, a.fechaIngreso) + 1>15,15,DATEDIFF($P{fechaFin}, a.fechaIngreso)+1))-ifnull((SELECT
                    (CASE idHrmTipoEvento
                        WHEN 2 THEN DATEDIFF(end_at, if(month(init_at)=month(date($P{fechaInicio})),init_at,$P{fechaInicio}))
                        WHEN 4 THEN dias
                        WHEN 6 THEN dias
                        WHEN 7 THEN dias
                    END) AS diasDesc
                    FROM
                        hrmEventos
                    WHERE
                        idHrmEmpleados=a.id and init_at>=$P{fechaInicio} and end_at<=$P{fechaFin} and idHrmTipoEvento in (2, 4 , 6, 7)),0)) as diasTrabajadosSQ,
                    ((if(DATEDIFF($P{fechaFin}, a.fechaIngreso) + 1>15,15,DATEDIFF($P{fechaFin}, a.fechaIngreso)+1))-ifnull((SELECT
                    (CASE idHrmTipoEvento
                        WHEN 2 THEN DATEDIFF(end_at, if(month(init_at)=month(date($P{fechaInicio})),init_at,$P{fechaInicio}))
                        WHEN 4 THEN dias
                        WHEN 6 THEN dias
                        WHEN 7 THEN dias
                    END) AS diasDesc
                    FROM
                        hrmEventos
                    WHERE
                        idHrmEmpleados=a.id and init_at>=$P{fechaInicio} and end_at<=$P{fechaFin} and idHrmTipoEvento in (2, 4 , 6, 7)),0)) as diasTrabajadosSQ,
                    ifnull((select sum(valor) from hrmComisiones where idHrmEmpleados=a.id and init_at=$P{fechaInicio} and end_at=$P{fechaFin}),0) as comisiones,
                    idFormaCalculoPrestaciones as tipoCalculoISR
                from
                    hrmEmpleados as a
                    left join hrmPuestos as b on(a.idHrmPuestos=b.id)
                    left join hrmFormasPago as c on(a.idHrmFormasPago=c.id)
                    left join paises as d on(a.idPaises=d.id)
                    left join hrmSedes as e on(a.idHrmSedes=e.id)
                    left join hrmDepartamentos as f on(a.idHrmDepartamentos=f.id)
                    left join centrosCosto as g on(f.idCentrosCosto=g.id)
	      where
                    a.idHrmDepartamentos=$P{idHrmDepartamentos} and a.idHrmPlanillas=$P{idHrmPlanilla}
                ORDER BY
                    a.fechaIngreso ASC;]]>
	</queryString>
