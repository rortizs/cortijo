	<queryString>
		<![CDATA[SELECT
    *
FROM
    libroVentas
WHERE
    year(fechaDocumento)=$P{year}
    and month(fechaDocumento)=$P{month}
    and idEmpresas=$P{idEmpresas}
    and idSucursales=$P{idSucursales}]]>
	</queryString>
