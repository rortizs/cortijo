<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facturaFTC" language="groovy" pageWidth="612" pageHeight="792" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="bc74d372-c3b1-4c55-9b12-b5a757c100cd">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idPedido" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*,
    b.cantidad,
    b.precio,
    b.total as totalXProducto,
    c.sku,
    upper(c.descLarga) as descLarga,
    upper(d.descripcion) as tipoVenta,
    e.userName as vendedor,
    f.razonSocial,
    f.nit as nitEmpresa,
    f.direccion as direccionEmpresa,
    f.telefono as telefonoEmpresa,
    i.diasCredito
FROM
    pedidos as a
    inner join pedidosDetalle as b on(a.id=b.idPedidos)
    inner join productos as c on(b.idProductos=c.id)
    inner join tipoVenta as d on(a.idTipoVenta=d.id)
    inner join usuarios as e on(a.idUsuarios=e.id)
    inner join empresas as f on(a.idEmpresas=f.id)
    left join clientes as i on(a.nit=i.nitC)
WHERE
    a.id = $P{idPedido}
GROUP BY b.idProductos]]>
	</queryString>
