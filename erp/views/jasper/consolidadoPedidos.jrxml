<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="consolidadoPedidos" language="groovy" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="78d3e38b-b979-4d1c-a267-2331ebfa15c0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="fechaInicio" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="fechaFin" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idEmpresas" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    c.sku,
    c.descLarga,
    sum(b.cantidad) as unidades,
    e.descripcion as unidadMedida,
    d.nombreComercial as empresa
FROM
    pedidos AS a
        INNER JOIN
    pedidosDetalle as b on(a.id=b.idPedidos)
        INNER JOIN
    productos as c on(b.idProductos=c.id)
        INNER JOIN
    empresas as d on(a.idEmpresas=d.id)
        INNER JOIN
    medidas as e on(c.idMedidas2=e.id)
where
    a.created_at between $P{fechaInicio} AND $P{fechaFin} AND a.idEmpresas=$P{idEmpresas} AND a.estado=1
group by
    b.idProductos]]>
	</queryString>
	<field name="sku" class="java.lang.String">
		<fieldDescription><![CDATA[Codigo,3]]></fieldDescription>
	</field>
	<field name="descLarga" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre,6]]></fieldDescription>
	</field>
	<field name="unidades" class="java.lang.Double"/>
	<field name="unidadMedida" class="java.lang.String"/>
	<field name="empresa" class="java.lang.String"/>
	<variable name="unidades_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{unidades}]]></variableExpression>
	</variable>
