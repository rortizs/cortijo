	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
	<parameter name="idCotizacion" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*,
    b.cantidad,
    b.precio,
    b.total as totalXProducto,
    c.sku,
    upper(c.descLarga) as descLarga,
    upper(d.descripcion) as tipoVenta,
    e.userName as vendedor,
    f.razonSocial,
    s.descripcion AS nombreComercial,
    f.nit as nitEmpresa,
    f.direccion as direccionEmpresa,
    f.telefono as telefonoEmpresa,
    i.diasCredito,
    case a.idEmpresas
	when 6 then 'cdc.jpg'
	when 3 then 'quitralco.jpg'
    end as logo
FROM
    cotizaciones as a inner join cotizacionesDetalle as b on(a.id=b.idCotizaciones)
    inner join productos as c on(b.idProductos=c.id)
    inner join tipoVenta as d on(a.idTipoVenta=d.id)
    inner join usuarios as e on(a.idUsuarios=e.id)
    inner join empresas as f on(a.idEmpresas=f.id)
    inner joing sucursales AS s ON (b.idSucursales = s.id)
    left join clientes as i on(a.nit=i.nitC)
WHERE
    a.id = $P{idCotizacion}
GROUP BY b.idProductos]]>
	</queryString>
