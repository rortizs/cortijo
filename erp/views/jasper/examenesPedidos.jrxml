<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ticket" language="groovy" pageWidth="215" pageHeight="841" columnWidth="175" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ef7fc291-cbdb-498a-bfc1-21504516806f">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idPedido" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idFamiliaNivel1" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
                            c.id as idPedido,
                            c.nombre,
                            replace(c.documento,'P-','') as documento,
                            c.created_at,
                            c.telefono,
                            c.observaciones,
                            a.cantidad,
                            a.idProductos,
                            b.sku,
                            b.descLarga AS descCorta,
                            precio AS costoUnitario,
                            a.total,
                            d.nombreC,
                            c.anticipo,
                            c.saldo,
                            e.descripcion AS area,
                            e.id AS idFamiliaNivel1,
                            d.edad AS edad,
                            c.id AS codCliente,
                            f.userName as vendedor
                        FROM
                            pedidosDetalle AS a
                                LEFT JOIN
                            productos AS b ON (a.idProductos = b.id)
                                LEFT JOIN
                            pedidos AS c ON (a.idPedidos = c.id)
                                LEFT JOIN
                            clientes AS d ON (c.nit = d.nitC && c.nombre=d.nombreF)
                                LEFT JOIN
                            familiaNivel1 AS e ON (b.idFamiliaNivel1 = e.id)
                                LEFT JOIN
                            usuarios as f on(c.idUsuarios=f.id)
                        WHERE
                            a.idPedidos =$P{idPedido}
                            and b.idFamiliaNivel1=$P{idFamiliaNivel1} group by idProductos]]>
	</queryString>
