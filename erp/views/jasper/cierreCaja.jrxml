	<parameter name="idSucursales" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*, DATE_FORMAT(a.created_at, '%d-%m-%Y') AS created_at,
    b.descripcion as sucursal,
    c.nombreComercial as empresa
FROM
    corteCaja as a inner join sucursales as b on(a.idSucursales=b.id)
    inner join empresas as c on(a.idEmpresas=c.id)
WHERE
    a.idSucursales = $P{idSucursales}
    AND DATE(a.created_at) = curdate()]]>
	</queryString>
