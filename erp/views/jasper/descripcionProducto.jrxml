<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="codigoBarras" language="groovy" pageWidth="144" pageHeight="72" orientation="Landscape" columnWidth="104" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e63fd170-0372-4303-b7e3-1bc39673b477">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idProducto" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select e.nombreComercial, p.sku,p.descLarga,p.descripcion
from productos as p
inner join empresas as e on p.idEmpresas=e.id
where p.id=$P{idProducto}]]>
	</queryString>
	<field name="nombreComercial" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre Comercial]]></fieldDescription>
	</field>
	<field name="sku" class="java.lang.String">
		<fieldDescription><![CDATA[Codigo,12]]></fieldDescription>
	</field>
	<field name="descLarga" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre,12]]></fieldDescription>
	</field>
	<field name="descripcion" class="java.lang.String">
		<fieldDescription><![CDATA[Descripción]]></fieldDescription>
	</field>
	<background>
		<band splitType="Stretch"/>
	</background>
	<pageHeader>
		<band height="1"/>
	</pageHeader>
	<detail>
		<band height="10">
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="0" width="104" height="10" uuid="2e6e120d-2da8-433a-a1ff-e80a66ee0a1e"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
