<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facDoanbo" language="groovy" pageWidth="369" pageHeight="600" columnWidth="329" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="49eef07f-7ecc-4748-924b-725081663898">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    day(ventas.fechaFactura) as day,
    month(ventas.fechaFactura) as month,
    year(ventas.fechaFactura) as year,
    ventas.nombre,
    ventas.direccion,
    ventas.nit,
    ventas.total,
    ventasDetalle.cantidad,
    substring(concat(ventasDetalle.sku,' - ',ventasDetalle.descLarga),1,34) as descLarga,
    ventasDetalle.total as totalProducto,
    ventas.totalEnLetras
FROM
    ventas
    inner join ventasDetalle on(ventas.id=ventasDetalle.idVentas)
WHERE
    ventas.id=$P{idVenta};]]>
	</queryString>
	<field name="day" class="java.lang.Long"/>
	<field name="month" class="java.lang.Long"/>
	<field name="year" class="java.lang.Long"/>
	<field name="nombre" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre]]></fieldDescription>
	</field>
	<field name="direccion" class="java.lang.String">
		<fieldDescription><![CDATA[Direccion]]></fieldDescription>
	</field>
	<field name="nit" class="java.lang.String">
		<fieldDescription><![CDATA[NIT]]></fieldDescription>
	</field>
	<field name="total" class="java.lang.Double">
		<fieldDescription><![CDATA[Total]]></fieldDescription>
	</field>
	<field name="cantidad" class="java.lang.Double">
		<fieldDescription><![CDATA[Cantidad]]></fieldDescription>
	</field>
	<field name="descLarga" class="java.lang.String"/>
	<field name="totalProducto" class="java.lang.Double"/>
	<field name="totalEnLetras" class="java.lang.String">
		<fieldDescription><![CDATA[Total En Letras]]></fieldDescription>
	</field>
