<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ordenCompra" language="groovy" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="5e88541b-c1e9-4afc-8f17-b6bcf9ecdb8c">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idComprasOrden" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	`a`.`id` AS `idOrdenCompra`,
	`a`.`documento` AS `documento`,
	`a`.`solicitadoPor` AS `solicitadoPor`,
	`deptos`.`descripcion` AS `idHrmDepartamentos`,
	`a`.`observaciones` AS `observaciones`,
	`b`.`descripcion` AS `idTipoOrdenCompra`,
           DATE_FORMAT(a.arribo_at, '%d-%m-%Y') AS `arribo_at`,
	a.tipoCambio,
	`c`.`descripcion` AS `idProveedores`,
	(CASE `a`.`status`
		WHEN 1 THEN 'Pendiente'
		WHEN 2 THEN 'Aprobada'
		WHEN 3 THEN 'Rechazada'
		WHEN 4 THEN 'Procesada'
	END) AS `status`,
	`f`.`userName` AS `idAdminUser`,
	`a`.`observacionesAuth` AS `observacionesAuth`,
	DATE_FORMAT(`a`.`created_at`, '%d-%m-%Y %H:%i:%s') AS `created_at`,
	DATE_FORMAT(`a`.`updated_at`, '%d-%m-%Y %H:%i:%s') AS `updated_at`,
	DATE_FORMAT(`a`.`auth_at`, '%d-%m-%Y %H:%i:%s') AS `auth_at`,
	`g`.`nombreComercial` AS `idEmpresas`,
	`e`.`userName` AS `idUsuarios`,
    	p.sku,
    	p.descLarga,
    	ocd.cantidad,
    	ocd.precio,
    	ocd.total,
	g.nit,
    g.direccion,
    g.telefono,
    g.razonSocial,
    a.montoEnLetras,
    m.descripcion as moneda
FROM
    `comprasOrdenes` `a`
    LEFT JOIN `tipoCompra` `b` ON (`a`.`idTipoOrdenCompra` = `b`.`id`)
    LEFT JOIN `proveedores` `c` ON (`a`.`idProveedores` = `c`.`id`)
    LEFT JOIN `hrmDepartamentos` `deptos` ON (`a`.`idHrmDepartamentos` = `deptos`.`id`)
    LEFT JOIN `usuarios` `e` ON (`a`.`idUsuarios` = `e`.`id`)
    LEFT JOIN `usuarios` `f` ON (`a`.`idAdminUser` = `f`.`id`)
    LEFT JOIN `empresas` `g` ON (`a`.`idEmpresas` = `g`.`id`)
    LEFT JOIN comprasOrdenesDetalle as ocd on(a.id=ocd.idComprasOrdenes)
    left join productos as p on(ocd.idProductos=p.id)
    inner join monedas as m on(a.idMonedas=m.id)
where
    a.id=$P{idComprasOrden} ]]>
	</queryString>
