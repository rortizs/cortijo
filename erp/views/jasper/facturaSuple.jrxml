	</field>
	<field name="medida" class="java.lang.String"/>
	<field name="dia" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="age" class="java.lang.String"/>
	<field name="mes" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="contado" class="java.lang.String"/>
	<field name="credito" class="java.lang.String"/>
	<field name="diasCredito" class="java.lang.Double">
		<fieldDescription><![CDATA[Dias Credito,3]]></fieldDescription>
	</field>
	<field name="precioSinIDP" class="java.lang.Double"/>
	<field name="totalSinIDP" class="java.lang.Double"/>
	<field name="idp" class="java.math.BigDecimal"/>
	<field name="totalIDP" class="java.lang.Double"/>
	<variable name="totalSinIDP" class="java.math.BigDecimal">
		<variableExpression><![CDATA[($F{cantidad}*$F{precioSinIDP})]]></variableExpression>
	</variable>
