	<parameter name="periodoInicial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="periodoFinal" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="mesInicial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="mesFinal" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idEmpresas" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.cuenta,
    a.cuentaContable,
    if(sum(saldo4)='0.00',' ',sum(saldo4)) as saldo4,
    if(sum(saldo3)='0.00',' ',sum(saldo3)) as saldo3,
    if(sum(saldo2)='0.00',' ',sum(saldo2)) as saldo2,
    if(sum(saldo1)='0.00',' ',sum(saldo1)) as saldo1,
    if(cuenta=1,sum(saldo1),0) as sumaActivo,
    if(cuenta>1,sum(saldo1),0) as sumaPasivo,
    (if(cuenta=1,sum(saldo1),0)-if(cuenta>1,sum(saldo1),0)) as resultado,
    b.razonSocial,
    b.nit,
    b.direccion,
    b.telefono,
 case $P{mesInicial}
    when '1' then 'ENERO'
    when '2' then 'FEBRERO'
    when '3' then 'MARZO'
    when '4' then 'ABRIL'
    when '5' then 'MAYO'
    when '6' then 'JUNIO'
    when '7' then 'JULIO'
    when '8' then 'AGOSTO'
    when '9' then 'SEPTIEMBRE'
    when '10' then 'OCTUBRE'
    when '11' then 'NOVIEMBRE'
    when '12' then 'DICIEMBRE'
    end as mesInicial,
    case $P{mesFinal}
    when '1' then 'ENERO'
    when '2' then 'FEBRERO'
    when '3' then 'MARZO'
    when '4' then 'ABRIL'
    when '5' then 'MAYO'
    when '6' then 'JUNIO'
    when '7' then 'JULIO'
    when '8' then 'AGOSTO'
    when '9' then 'SEPTIEMBRE'
    when '10' then 'OCTUBRE'
    when '11' then 'NOVIEMBRE'
    when '12' then 'DICIEMBRE'
    end as mesFinal
FROM
    contBalanceGeneral AS a
        INNER JOIN
    empresas AS b ON (a.idEmpresas = b.id)
WHERE
    periodo between $P{periodoInicial} and $P{periodoFinal}
    and mes between $P{mesInicial} and $P{mesFinal}
    and idEmpresas=$P{idEmpresas}
group by
    cuenta]]>
	</queryString>
