<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="reciboLaxTravel" language="groovy" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d7cd9dfb-300f-42ba-847f-76798f15a6c3">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="recibo" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select x.*,date_format(x.created_at, '%d/%m/%Y') as fechaRecibo, e.nombreComercial as nombreEmpresa,e.direccion as direccionEmpresa,e.mailEmpresa as correoEmpresa,e.telefono as telefonoEmpresa,
e.nit as nitEmpresa,c.codigo as codigoCLiente,c.nombreC as nombreCliente,u.username as nombreUsuario,u.codigoUsuario,
CONCAT(v.serie, '-',v.correlativo) AS documento,CONCAT(v.seriePagare,'-',v.correlativoPagare) AS pagare,
date_format(v.fechaFactura, '%d/%m/%Y') as fechaFactura, v.conceptoVenta
from cxc x
inner join empresas e on x.idEmpresas=e.id
inner join clientes c on x.idClientes=c.id
inner join ventas v on x.idVentas = v.id
left join usuarios u on v.idUsuarios = u.id
where x.idDocumento=$P{recibo}]]>
	</queryString>
