	<queryString>
		<![CDATA[SELECT
    *
FROM
    documentosBancarios
WHERE
    fechaDocumento BETWEEN $P{fechaInicio} AND $P{fechaFin}
    AND idCuentasBancarias=$P{idCuentasBancarias}
    AND idEmpresas=$P{idEmpresas}
ORDER BY fechaDocumento ASC]]>
	</queryString>
