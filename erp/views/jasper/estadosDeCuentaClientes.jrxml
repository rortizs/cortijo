	</parameter>
	<queryString>
		<![CDATA[SELECT
    cxc.idClientes,
    idVentas,
    nombreC AS cliente,
    nitC AS nit,
    direccionC AS direccion,
    creditos,
    debitos,
    cxc.saldo,
    date_format(cxc.created_at,'%d-%m-%Y') AS fecha,
    e.nombreComercial,
    CASE idTipoDocumento
        WHEN '1' THEN 'FACTURA'
        WHEN '2' THEN 'RECIBO'
        WHEN '3' THEN 'FACTURA'
        WHEN '4' THEN 'DEPOSITO'
        WHEN '5' THEN 'VALE'
    END AS documento,
    idDocumento AS correlativo,
    ifnull(facLiquidadas,'-') as facLiquidadas
FROM
    cxc
        left JOIN
    clientes AS c ON cxc.idClientes = c.id
        left JOIN
    empresas AS e ON cxc.idEmpresas = e.id
        inner join
    ventas as v on(cxc.idVentas=v.id)
WHERE
    cxc.idClientes = $P{idcliente}
    AND cxc.idEmpresas = $P{idEmpresas} AND date(cxc.created_at) between $P{fechaInicio} and $P{fechaFin}
    AND v.total>0
ORDER BY DATE(cxc.created_at) ASC;]]>
	</queryString>
