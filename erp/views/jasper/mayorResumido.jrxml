<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="diarioDetallado" language="groovy" pageWidth="612" pageHeight="792" columnWidth="572" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="21a231e7-bfdb-4504-a738-fcdccf53248d">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idEmpresas" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="yearInicial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="yearFinal" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="mesInicial" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="mesFinal" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="cuenta" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.numero,
    a.id as idPartida,
    c.cuenta,
    upper(c.descripcion) as cuentaContable,
    date_format(a.partida_at,'%d-%m-%Y') as fecha,
    upper(a.descripcion) as concepto,
    b.debe,
    b.haber,
    g.razonSocial,
    g.nit,
    g.direccion,
    g.telefono
FROM
    partidas AS a
        INNER JOIN
    partidasDetalle AS b ON (a.id = b.idPartidas)
		INNER JOIN
    nomenclatura as c on(b.idNomenclatura=c.id)
		LEFT JOIN
    ventas as d on(a.id=d.idPartidas)
		LEFT JOIN
    compras as e on(a.partida_at=e.fechaContabilizacion)
		LEFT JOIN
    proveedores as f on(e.idProveedores=f.id)
		INNER JOIN
    empresas as g on(a.idEmpresas=g.id)
WHERE
    a.idEmpresas=$P{idEmpresas}
    and year(a.partida_at) between $P{yearInicial} and $P{yearFinal}
    and month(a.partida_at) between $P{mesInicial} and $P{mesFinal}
group by
    numero,cuenta
order by
   cuenta,date(fecha) asc]]>
	</queryString>
