<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facturaSuple" language="groovy" pageWidth="612" pageHeight="396" orientation="Landscape" columnWidth="572" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="d681caab-ddd9-4695-b48b-8a591dc83e4b">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    UPPER(ventas.nombre) AS cliente,
    UPPER(ventas.direccion) AS direccion,
    ventas.nit,
    DAY(ventas.fechaFactura) AS day,
    MONTH(ventas.fechaFactura) AS month,
    YEAR(ventas.fechaFactura) AS year,
    UPPER(ventas.conceptoVenta) AS conceptoVenta,
    if(ventas.tipoCambio!='1.0000',ventas.totalDolares,ventas.total) AS total,
    if(ventas.tipoCambio!='1.0000',ventas.totalEnLetrasDolares,ventas.totalEnLetras) AS totalEnLetras,
    if(ventas.tipoCambio!='1.0000',concat('T.C.: ',ventas.tipoCambio),'') as tipoCambio,
    if(ventas.tipoCambio!='1.0000','$','Q') as moneda,
    ventasDetalle.cantidad,
    ventasDetalle.descLarga,
    ventasDetalle.total as totalProducto
FROM
    ventas left join
    ventasDetalle on(ventas.id=ventasDetalle.idVentas)
WHERE
   ventas.id =$P{idVenta}]]>
	</queryString>
