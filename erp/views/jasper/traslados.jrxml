	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idTraslados" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select
    a.*,
    p.sku,
    p.descLarga,
    b.cantidad
from
    vw_traslados as a
        inner join
    trasladosDetalle as b ON (a.id = b.idTraslados)
        inner join
    productos as p ON (b.idProductos = p.id)
where
    a.id=$P{idTraslados}]]>
	</queryString>
