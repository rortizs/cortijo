				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[REPORTE DE MARCAS POR FECHA]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="40" width="179" height="20" uuid="2228edc4-87dc-4bd7-bd36-208117446054"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[EMPLEADO:]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="60" width="179" height="20" uuid="eb2c96c4-665d-4478-babd-279aea103398"/>
				<textElement>
					<font isBold="true"/>
				</textElement>
				<text><![CDATA[RANGO FECHA REPORTE:]]></text>
			</staticText>
			<textField>
				<reportElement x="179" y="60" width="393" height="20" uuid="fb67dd6b-8389-4b1e-8511-658f85ae91d2"/>
				<textFieldExpression><![CDATA["DEL "+$P{fechaInicio}+" AL "+$P{fechaFin}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="179" y="40" width="393" height="20" uuid="8bfd25da-b70f-442e-a963-b6725034dbec"/>
				<textFieldExpression><![CDATA[$F{codigoEmpleado}+" - "+$F{empleado}]]></textFieldExpression>
			</textField>
		</band>
	</title>
