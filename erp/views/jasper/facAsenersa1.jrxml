	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    nombre,
    nit,
    clientes.direccionC,
    conceptoVenta,
    round((total/1.12),2) as subtotal,
    iva,
    total,
    totalEnLetras,
    date_format(fechaFactura,'%d/%m/%Y') as fechaFactura,
    if(idTipoVenta=2,clientes.diasCredito,'') as credito
FROM
    ventas left join clientes on(ventas.nit=clientes.nitC)
where
    ventas.id=$P{idVenta}]]>
	</queryString>
