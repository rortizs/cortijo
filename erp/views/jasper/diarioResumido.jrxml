	<queryString>
		<![CDATA[SELECT
    tipoOperacionPartida,
    idPartida,
    numeroPartida,
    fechaPartida,
    concepto,
    razonSocial,
    direccion,
    nit,
    telefono,
    cuenta,
    cuentaContable,
    centroCosto,
    SUM(debe) AS debe,
    SUM(haber) AS haber,
    cuadre
FROM
    vw_diario
WHERE
    idEmpresas = $P{idEmpresas}
    AND periodo BETWEEN $P{yearInicial} AND $P{yearFinal}
    AND mes BETWEEN $P{mesInicial} AND $P{mesFinal}
    AND idTipoOperacionPartida IN (1,2,3,4)
GROUP BY cuenta
ORDER BY idTipoOperacionPartida ASC ]]>
	</queryString>
