	<queryString>
		<![CDATA[SELECT
    a.nombreC,a.nitC
FROM
    clientes as a left join clientes20180621 as b
    on(a.nitC=b.nitC)
where
    a.idClasificacionClientes!=3 and b.id is null
group by
    a.nitC]]>
	</queryString>
	<field name="nombreC" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre del Cliente,6]]></fieldDescription>
	</field>
	<field name="nitC" class="java.lang.String">
