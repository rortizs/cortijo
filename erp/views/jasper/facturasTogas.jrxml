<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facturasTogas" language="groovy" pageWidth="291" pageHeight="428" columnWidth="251" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c473386a-97ca-43da-badd-bff8654be08b">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select  v.nombre,
v.direccion,
v.nit,
v.totalEnLetras,
v.fechaFactura,
DATE_FORMAT(v.fechaFactura,'%d') as dia,
DATE_FORMAT(v.fechaFactura,'%m') as mes,
DATE_FORMAT(v.fechaFactura,'%Y') as año,
vd.cantidad ,
vd.precio ,
v.total,
vd.total as totalDetalle,
p.descLarga
FROM ventas as v
INNER JOIN ventasDetalle as vd ON (v.id = vd.idVentas)
inner join productos as p on(vd.idProductos=p.id)
WHERE v.id=$P{idVenta}]]>
	</queryString>
