	</field>
	<field name="total" class="java.lang.Double">
		<fieldDescription><![CDATA[Total]]></fieldDescription>
	</field>
	<field name="totalDetalle" class="java.lang.Double"/>
	<field name="descLarga" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre]]></fieldDescription>
	</field>
	<variable name="total_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{total}]]></variableExpression>
	</variable>
	<variable name="totalEnLetras_1" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{totalEnLetras}]]></variableExpression>
	</variable>
