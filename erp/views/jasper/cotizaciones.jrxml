<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="cotizaciones" language="groovy" pageWidth="612" pageHeight="792" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="bc74d372-c3b1-4c55-9b12-b5a757c100cd">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idCotizacion" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*,
    b.cantidad,
    b.precio,
    b.total as totalXProducto,
    c.sku,
    upper(b.descLarga) as descLarga,
    upper(d.descripcion) as tipoVenta,
    e.userName as vendedor,
    f.razonSocial,
    f.nit as nitEmpresa,
    f.direccion as direccionEmpresa,
    f.telefono as telefonoEmpresa,
    i.diasCredito
FROM
    cotizaciones as a 
    INNER JOIN cotizacionesDetalle as b ON (a.id = b.idCotizaciones)
    INNER JOIN productos as c ON (b.idProductos = c.id)
    INNER JOIN tipoVenta as d ON (a.idTipoVenta = d.id)
    INNER JOIN usuarios as e ON (a.idUsuarios = e.id)
    INNER JOIN empresas as f ON (a.idEmpresas = f.id)
    LEFT JOIN clientes as i ON (a.nit = i.nitC)
WHERE
    a.id = $P{idCotizacion}
GROUP BY b.idProductos, b.descLarga]]>
	</queryString>
