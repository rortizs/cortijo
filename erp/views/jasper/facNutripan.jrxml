	</field>
	<field name="conceptoVenta" class="java.lang.String">
		<fieldDescription><![CDATA[Concepto de Venta]]></fieldDescription>
	</field>
	<field name="total" class="java.lang.Double">
		<fieldDescription><![CDATA[Total]]></fieldDescription>
	</field>
	<field name="totalEnLetras" class="java.lang.String">
		<fieldDescription><![CDATA[Total En Letras]]></fieldDescription>
	</field>
	<field name="fechaFactura" class="java.lang.String"/>
	<field name="sku" class="java.lang.String"/>
	<field name="cantidad" class="java.lang.Double">
		<fieldDescription><![CDATA[Cantidad]]></fieldDescription>
	</field>
	<field name="precio" class="java.lang.Double">
		<fieldDescription><![CDATA[Precio]]></fieldDescription>
	</field>
	<field name="totalProducto" class="java.lang.Double"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="descuento" class="java.lang.Double">
		<fieldDescription><![CDATA[Descuento]]></fieldDescription>
	</field>
	<field name="descuentoP" class="java.lang.String">
		<fieldDescription><![CDATA[Descuento %]]></fieldDescription>
	</field>
	<field name="dayFactura" class="java.lang.String"/>
	<field name="monthFactura" class="java.lang.String"/>
	<field name="yearFactura" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="84" splitType="Stretch">
