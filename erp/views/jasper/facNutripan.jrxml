<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facNutripan" language="groovy" pageWidth="612" pageHeight="792" columnWidth="592" leftMargin="20" rightMargin="0" topMargin="0" bottomMargin="0" uuid="b8580b9f-2d70-448f-bafa-7c4a94918e7c">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.id as idVenta,
    nombre,
    nit,
    a.direccion,
    conceptoVenta,
    a.total,
    totalEnLetras,
    date_format(fechaFactura,'%d/%m/%Y') as fechaFactura,
    case length(c.sku)
      when 1 then concat('000000000000',c.sku)
      when 2 then concat('00000000000',c.sku)
      when 3 then concat('0000000000',c.sku)
      when 4 then concat('000000000',c.sku)
      when 5 then concat('00000000',c.sku)
      when 6 then concat('0000000',c.sku)
      when 7 then concat('000000',c.sku)
      when 8 then concat('00000',c.sku)
      when 9 then concat('0000',c.sku)
      when 10 then concat('000',c.sku)
      when 11 then concat('00',c.sku)
      when 12 then concat('0',c.sku)
      when 13 then c.sku
    end as sku,
    c.cantidad,
    c.precio,
    c.total as totalProducto,
    d.descLarga as descripcion,
    a.descuento,
    a.descuentoP,
    date_format(fechaFactura,'%d') as dayFactura,
    date_format(fechaFactura,'%m') as monthFactura,
    date_format(fechaFactura,'%Y') as yearFactura
FROM
    ventas as a
    left join clientes as b on(a.nombre=b.nombreC)
    left join ventasDetalle as c on(a.id=c.idVentas)
    left join productos as d on(c.idProductos=d.id)
where
    a.id=$P{idVenta}
group by
    c.idProductos]]>
	</queryString>
