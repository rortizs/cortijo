<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ticket" language="groovy" pageWidth="215" pageHeight="841" columnWidth="175" leftMargin="20" rightMargin="20" topMargin="0" bottomMargin="144" uuid="ef7fc291-cbdb-498a-bfc1-21504516806f">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    concat(c.serie,'-',c.correlativo) as documento,
    c.created_at,
    a.cantidad,
    a.idProductos,
    b.sku,
    b.descLarga as descCorta,
    precio as costoUnitario,
    a.total,
    e.razonSocial,
    e.direccion,
    e.nit,
    c.nit as nitCliente,
    date_format(current_timestamp,'%d-%m-%Y %H:%i:%s') as fechaGeneracion,
    u.userName as vendedor
FROM
    ventasDetalle as a
    inner join productos as b on(a.idProductos=b.id)
    inner join ventas as c on(a.idVentas=c.id)
    inner join empresas as e on(c.idEmpresas=e.id)
    inner join usuarios as u on(c.idUsuarios=u.id)
WHERE
    a.idVentas =$P{idVenta}]]>
	</queryString>
