	</field>
	<field name="nitCliente" class="java.lang.String"/>
	<field name="fechaGeneracion" class="java.lang.String"/>
	<field name="vendedor" class="java.lang.String"/>
	<variable name="total_1" class="java.lang.Double" calculation="Sum">
