<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ticket" language="groovy" pageWidth="215" pageHeight="841" columnWidth="175" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ef7fc291-cbdb-498a-bfc1-21504516806f">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idCotizacion" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
	c.nombre,
	c.documento,
          c.created_at,
	c.telefono,
	c.observaciones,
	a.cantidad,
	a.idProductos,
	b.sku,
	b.descLarga as descCorta,
	precio as costoUnitario,
	a.total
FROM
	cotizacionesDetalle as a inner join productos as b on(a.idProductos=b.id)
	inner join cotizaciones as c on(a.idCotizaciones=c.id)
WHERE
	a.idCotizaciones =$P{idCotizacion}]]>
	</queryString>
	<field name="nombre" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre]]></fieldDescription>
	</field>
	<field name="documento" class="java.lang.String">
		<fieldDescription><![CDATA[Documento]]></fieldDescription>
	</field>
	<field name="created_at" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha de Creación]]></fieldDescription>
	</field>
	<field name="telefono" class="java.lang.String">
