<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="liquidacionesCajaChica" language="groovy" pageWidth="612" pageHeight="792" columnWidth="572" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="53ea422f-4575-481a-a257-1c41c721269c">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idCajaChica" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*,
    concat(d.numeroCuenta,'-',d.nombreCuenta) as cuentaBancaria,
    b.noCheque,
    concat(c.serieFactura,'-',c.noFactura) as factura,
    c.conceptoCompra,
    date_format(c.fechaFactura,'%d-%m-%Y') as fechaFactura,
    c.total,
    e.razonSocial,
    e.nit as nit,
    e.direccion,
    e.telefono,
    f.descripcion as proveedor,
    date_format(a.created_at,'%d-%m-%Y') as fechaCajaChica
FROM
    cajaChica as a
    inner join cheques as b on(a.idCheques=b.id)
    inner join compras as c on(a.id=c.idCajaChica)
    inner join cuentasBancarias as d on(b.idCuentasBancarias=d.id)
    inner join empresas as e on(a.idEmpresas=e.id)
    left join proveedores as f on(c.idProveedores=f.id)
WHERE
    a.id = $P{idCajaChica}]]>
	</queryString>
