	</field>
	<field name="debitos" class="java.lang.Double"/>
	<field name="creditos" class="java.lang.Double"/>
	<field name="saldo" class="java.lang.Double">
		<fieldDescription><![CDATA[Saldo Por Pagar]]></fieldDescription>
	</field>
	<field name="idTipoCuentaContable" class="java.lang.Integer">
		<fieldDescription><![CDATA[Tipo de Cuenta]]></fieldDescription>
	</field>
	<field name="razonSocial" class="java.lang.String">
		<fieldDescription><![CDATA[Razón Social]]></fieldDescription>
	</field>
	<field name="nit" class="java.lang.String">
		<fieldDescription><![CDATA[Número Identificación Tributario]]></fieldDescription>
	</field>
	<field name="direccion" class="java.lang.String">
		<fieldDescription><![CDATA[Dirección]]></fieldDescription>
	</field>
	<field name="telefono" class="java.lang.String">
		<fieldDescription><![CDATA[Teléfonos]]></fieldDescription>
	</field>
	<variable name="inicial_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{inicial}]]></variableExpression>
	</variable>
	<variable name="debitos_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{debitos}]]></variableExpression>
	</variable>
	<variable name="creditos_1" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{creditos}]]></variableExpression>
	</variable>
	<variable name="saldo_1" class="java.lang.Double" calculation="Sum">
