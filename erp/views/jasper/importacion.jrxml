	<property name="ireport.y" value="0"/>
	<parameter name="idImportacion" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idEmpresas" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    *,
    ROUND(((seguro / cantidad)), 2) AS seguroProd,
    ROUND(((flete / totalPiezas) * cantidad), 2) AS fleteProd,
    ROUND(((dua / totalPiezas) * cantidad), 2) AS duaProd,
    ROUND(((otros / totalPiezas) * cantidad), 2) AS otrosProd,
    ROUND(((dai / totalPiezas) * cantidad), 2) AS daiProd,
    ROUND(((totalGastos / totalPiezas) * cantidad), 2) AS totalGastosProd,
    ROUND(totalQuetzales + ((totalGastos / totalPiezas) * cantidad),2) AS costosProd,
    ROUND((iva / totalPiezas) * cantidad, 2) AS ivaProd,
    ROUND((totalQuetzales + ((totalGastos / totalPiezas) * cantidad)) + ((iva / totalPiezas) * cantidad),2) AS costoMasIva,
    round(((((totalDolares*tipoCambio)/totalQuetzalesI)*totalGastos)+totalQuetzales)/cantidad,2) as costoProrrateado,
    round(((((totalDolares*tipoCambio)/totalQuetzalesI)*totalGastos)+totalQuetzales),2) AS costoTotalProrrateado,
    round(precioCosto+((((totalDolares*tipoCambio)/totalQuetzalesI)*totalGastos)+totalQuetzales)/cantidad,2) as costoNuevo
FROM
    vw_importacionJasper
WHERE
    idImportacion = $P{idImportacion} and idEmpresas= $P{idEmpresas}]]>
	</queryString>
