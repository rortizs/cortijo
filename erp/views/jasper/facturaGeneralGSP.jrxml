<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facturaFTC" language="groovy" pageWidth="572" pageHeight="752" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="bc74d372-c3b1-4c55-9b12-b5a757c100cd">
	<property name="ireport.zoom" value="1.3310000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="192"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="reimpresion" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    a.*,
    b.cantidad,
    b.precio,
    b.total as totalXProducto,
    c.sku,
    upper(c.descLarga) as descLarga,
    upper(d.descripcion) as tipoVenta,
    i.diasCredito,
    i.id as codigoCliente,
    if(anulacion=1,'ANULADA','ACTIVA') as estadoFactura
FROM
    ventas as a 
    left join ventasDetalle as b on(a.id=b.idVentas)
    left join productos as c on(b.idProductos=c.id)
    left join tipoVenta as d on(a.idTipoVenta=d.id)
    left join clientes as i on(a.nit=i.nitC)
WHERE
    a.id = $P{idVenta}
GROUP BY
   b.idProductos]]>
	</queryString>
