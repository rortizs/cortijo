<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Cheques" language="groovy" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ef5192bf-dfe4-498c-b09a-5f845fc7d765">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idCheque" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    *,
    if(noNegociables = 'si','No Negociable','') as noNegociable,
    upper(n.descripcion) as cuentaContable,
    upper(e.nombreComercial) as empresa,
    upper(f.userName) as usuario,
    substr(fechaCheque,1,2) as day,
    case substr(fechaCheque,4,2)
	when '01' then 'Enero'
      	when '02' then 'Febrero'
      	when '03' then 'Marzo'
      	when '04' then 'Abril'
      	when '05' then 'Mayo'
      	when '06' then 'Junio'
      	when '07' then 'Julio'
      	when '08' then 'Agosto'
      	when '09' then 'Septiembre'
      	when '10' then 'Octubre'
      	when '11' then 'Noviembre'
      	when '12' then 'Diciembre'
	end as month,
    substr(fechaCheque,7,4) as year
FROM
    vw_cheques as v
        left join
    partidas as p ON (v.idPartidas = p.numero)
        left join
    partidasDetalle as pd ON (p.id = pd.idPartidas)
        left join
    nomenclatura as n ON (pd.idNomenclatura = n.id)
        left join
    empresas as e on(v.idEmpresas=e.nombreComercial)
        left join
    usuarios as f on(v.idUsuarios=f.userName)
where
    v.id = $P{idCheque}]]>
	</queryString>
