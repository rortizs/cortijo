	</parameter>
	<parameter name="fechaFin" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idCuentaBancaria" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="idEmpresas" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="fechaInicio2" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="fechaFin2" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    date_format(fechaDocumento,'%d-%m-%Y') as fechaDocumento,
    tipoDocumento,
    noDocumento,
    status,
    credito,
    debito,
    numeroCuenta,
    banco,
    nombreComercial,
    direccion,
    telefono,
    nit,
    (credito-debito) as saldo,
    Monto,
    (SELECT
			sum((credito-debito))
	FROM
		documentosBancarios
	WHERE
		 fechaDocumento BETWEEN $P{fechaInicio} AND $P{fechaFin}
		 AND idCuentasBancarias=$P{idCuentaBancaria}
		 AND idEmpresas = $P{idEmpresas}
	ORDER BY fechaDocumento ASC) as saldoLibros,
     (SELECT
			sum((credito-debito))
	FROM
		documentosBancarios
	WHERE
		 fechaDocumento BETWEEN $P{fechaInicio} AND $P{fechaFin}
		 AND idCuentasBancarias=$P{idCuentaBancaria}
		 AND idEmpresas = $P{idEmpresas}
         AND status='CONCILIADO'
	ORDER BY fechaDocumento ASC) as saldoBancos,
    (SELECT
			sum((credito-debito))
	FROM
		documentosBancarios
	WHERE
		 fechaDocumento BETWEEN $P{fechaInicio} AND $P{fechaFin}
		 AND idCuentasBancarias=$P{idCuentaBancaria}
		 AND idEmpresas = $P{idEmpresas}
         AND status!='CONCILIADO'
	ORDER BY fechaDocumento ASC) as saldoCirculacion
FROM
    documentosBancarios
WHERE
     fechaDocumento BETWEEN $P{fechaInicio} AND $P{fechaFin}
     AND idCuentasBancarias=$P{idCuentaBancaria}
     AND idEmpresas = $P{idEmpresas}
     AND status!='CONCILIADO'
ORDER BY fechaDocumento ASC]]>
	</queryString>
