<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facConalib2" language="groovy" pageWidth="572" pageHeight="356" orientation="Landscape" columnWidth="552" leftMargin="20" rightMargin="0" topMargin="0" bottomMargin="0" uuid="f9d62d60-b50a-4878-b263-df8f56e27d4d">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.id as idVenta,
    nombre,
    nit,
    a.direccion,
    if(conceptoVenta='.','',conceptoVenta) as conceptoVenta,
    a.total,
    totalEnLetras,
    date_format(fechaFactura,'%d/%m/%Y') as fechaFactura,
    c.sku,
    c.cantidad,
    c.precio,
    c.total as totalProducto,
    d.descLarga as descripcion,
    if(a.descuento=0.00,'',a.descuento) as descuento,
    if(a.descuentoP=0,'',concat('DESCUENTO: ',a.descuentoP,'%')) as descuentoP,
    day(fechaFactura) as diaFactura,
    month(fechaFactura) as mesFactura,
    substring(year(fechaFactura),3,2) as yearFactura
FROM
    ventas as a
    left join clientes as b on(a.nit=b.nitC and b.idEmpresas=a.idEmpresas)
    left join ventasDetalle as c on(a.id=c.idVentas)
    left join productos as d on(c.idProductos=d.id)
where
    a.id=$P{idVenta}]]>
	</queryString>
	<field name="idVenta" class="java.lang.Integer"/>
	<field name="nombre" class="java.lang.String">
