	</field>
	<field name="totalEnLetras" class="java.lang.String">
		<fieldDescription><![CDATA[Total En Letras]]></fieldDescription>
	</field>
	<field name="fechaFactura" class="java.lang.String">
		<fieldDescription><![CDATA[Fecha de Factura]]></fieldDescription>
	</field>
	<field name="sku" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="cantidad" class="java.lang.Double">
		<fieldDescription><![CDATA[Cantidad]]></fieldDescription>
	</field>
	<field name="precio" class="java.lang.Double">
