	</field>
	<field name="totalProducto" class="java.lang.Double"/>
	<field name="descripcion" class="java.lang.String">
		<fieldDescription><![CDATA[DESCRIPCION,12]]></fieldDescription>
	</field>
	<field name="descuento" class="java.lang.String">
		<fieldDescription><![CDATA[Descuento]]></fieldDescription>
	</field>
	<field name="descuentoP" class="java.lang.String">
		<fieldDescription><![CDATA[Descuento %]]></fieldDescription>
	</field>
	<field name="diaFactura" class="java.lang.Long"/>
	<field name="mesFactura" class="java.lang.Long"/>
	<field name="yearFactura" class="java.lang.String"/>
