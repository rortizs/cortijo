<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="cotizacionTogas" language="groovy" pageWidth="612" pageHeight="792" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="bc74d372-c3b1-4c55-9b12-b5a757c100cd">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="120"/>
	<parameter name="idCotizacion" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.documento,
    a.total,
    DATE_FORMAT(a.created_at,'%d/%m/%Y') as fechaCotizacion,
    b.cantidad,
    b.precio,
    b.idProductos,
    b.total as totalXProducto,
    c.sku,
    upper(c.descLarga) as descLarga,
    upper(d.descripcion) as tipoVenta,
    e.userName as vendedor,
    f.razonSocial,
    f.nit as nitEmpresa,
    f.direccion as direccionEmpresa,
    f.telefono as telefonoEmpresa,
    f.mailEmpresa,
    p.idProductoPrincipal,
    p.unidades,
    g.sku as sku2,
    upper(g.descLarga) as descLarga2,
    h.codigo as codigoCliente,
    h.nitC as nitCliente,
    h.contacto as contactoCliente,
    h.nombreC as nombreCliente,
    h.direccionC as direccionCliente,
    h.telefonoC as telefonoCliente,
    h.mail as correoCliente,
    h.nombreC as nombreCliente
FROM
     productosComponentes as p
    inner join productos as c on(p.idProductos=c.id)
    inner join productos as g on(p.idProductoPrincipal=g.id)
    inner join cotizacionesDetalle as b on(b.idProductos=p.idProductoPrincipal)
    inner join cotizaciones as a on(a.id=b.idCotizaciones)
    inner join tipoVenta as d on(a.idTipoVenta=d.id)
    inner join usuarios as e on(a.idUsuarios=e.id)
    inner join empresas as f on(a.idEmpresas=f.id)
    inner join clientes as h on(a.idClientes=h.id)
WHERE
    a.id = $P{idCotizacion}
ORDER BY b.idProductos]]>
	</queryString>
