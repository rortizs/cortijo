	<queryString>
		<![CDATA[SELECT
    date_format(fechaDocumento,'%d-%m-%Y') as fechaDocumento,
    tipoDocumento,
    noDocumento,
    status,
    credito,
    debito,
    numeroCuenta,
    banco,
    nombreComercial,
    direccion,
    telefono,
    nit,
    (credito-debito) as saldo,
(SELECT sum((credito-debito)) FROM documentosBancarios WHERE fechaDocumento<$P{fechaInicio} AND idCuentasBancarias=1 AND idEmpresas = 6 AND status='CONCILIADO') as saldoInicial
FROM
    documentosBancarios
WHERE
     fechaDocumento BETWEEN $P{fechaInicio} AND $P{fechaFin}
     AND idCuentasBancarias=$P{idCuentaBancaria}
     AND idEmpresas = $P{idEmpresa}
     AND status='CONCILIADO'
ORDER BY fechaDocumento ASC]]>
	</queryString>
