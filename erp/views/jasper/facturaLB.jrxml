<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="facturaLB" language="groovy" pageWidth="382" pageHeight="569" columnWidth="318" leftMargin="36" rightMargin="28" topMargin="20" bottomMargin="20" uuid="55bb5a71-fdae-4e2b-9142-ab7ed995ff74">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    a.*,
    date_format(a.fechaFactura,'%d-%m-%Y') as fechaFac,
    b.cantidad,
    b.precio,
    b.total as totalXProducto,
    c.sku,
    upper(c.descLarga) as descLarga,
    upper(d.descripcion) as tipoVenta,
    i.diasCredito,
    if(anulacion=1,'ANULADA','ACTIVA') as estadoFactura
FROM
    ventas as a inner join ventasDetalle as b on(a.id=b.idVentas)
    inner join productos as c on(b.idProductos=c.id)
    inner join tipoVenta as d on(a.idTipoVenta=d.id)
    left join clientes as i on(a.nit=i.nitC)
WHERE
    a.id = $P{idVenta}
GROUP BY
   b.idProductos]]>
	</queryString>
