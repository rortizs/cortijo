<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ticket" language="groovy" pageWidth="215" pageHeight="841" columnWidth="175" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" isIgnorePagination="true" uuid="ef7fc291-cbdb-498a-bfc1-21504516806f">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idVenta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    upper(ventas.nombre) as nombre,
    ventas.nit,
    upper(ventas.direccion) as direccion,
    ventasDetalle.cantidad,
    productos.descLarga,
    ventasDetalle.total as totalProducto,
    empresas.razonSocial,
    empresas.nombreComercial,
    empresas.nit as nitEmpresa,
    empresas.direccion as direccionEmpresa,
    ventas.serie,
    ventas.correlativo,
    ventas.fechaFactura,
    ventas.fechaEmisionFEL,
    ventas.autorizacionFEL,
    ventas.subtotal,
    ventas.descuento,
    ventas.total,
    if(ventas.idTipoVenta=1,'CONTADO','CREDITO') as tipoVenta,
    ventas.conceptoVenta,
    ventas.totalEnLetras
FROM
    ventas inner join
    ventasDetalle on (ventas.id=ventasDetalle.idVentas) inner join
    productos on(ventasDetalle.idProductos=productos.id) inner join
    empresas on(ventas.idEmpresas=empresas.id)
WHERE
    ventas.id =$P{idVenta}]]>
	</queryString>
